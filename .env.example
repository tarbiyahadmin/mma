# Vite only exposes variables prefixed with VITE_ to the browser bundle.
# Copy to .env and adjust values. Keep these in sync with studio/sanity.cli.ts.

VITE_SANITY_PROJECT_ID=yourProjectId
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2024-01-01

# Do NOT put write tokens here for production sites — they are visible in the bundle.
# Public datasets work for read-only queries without a token.
# VITE_SANITY_TOKEN=
